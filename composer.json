{
    "name": "jdz/template",
    "type": "library",
    "description": "Template rendering infrastructure with Twig support",
    "homepage": "https://github.com/joffreydemetz/template",
    "license": "MIT",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jdz/data": "^2.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Template\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Template\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always --testdox",
        "test-coverage": "phpunit --coverage-html coverage"
    }
}
